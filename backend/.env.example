# ─── DATABASE ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/clawbid
REDIS_URL=redis://localhost:6379

# ─── APP ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_change_this
WEBHOOK_HMAC_SECRET=your_webhook_hmac_secret_change_this

# ─── BANKR LLM GATEWAY ──────────────────────────────────
